# ─────────────────────────────────────────────
# 프로덕션 환경변수 — .env.prod 로 복사 후 수정
# ─────────────────────────────────────────────

# 도메인 (Caddyfile 의 YOUR_DOMAIN 과 동일하게)
DOMAIN=your.domain.com

# DB
POSTGRES_DB=legal_rag
POSTGRES_USER=legal_rag
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 보안 (32자 이상 랜덤 문자열)
JWT_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_32CHARS_MIN

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG 설정
RAG_TOP_K=7
RAG_RETRIEVE_CANDIDATES=10
RAG_ANSWER_MAX_TOKENS=800
RAG_HYDE_ENABLED=true
RAG_RERANK_ENABLED=true
RAG_CONTEXT_MAX_CHARS=8000
RAG_MAX_SOURCE_DISTANCE=1.25
