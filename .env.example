# Copy this file to .env for local development.
# Never commit real secret values.

APP_ENV=local
APP_NAME=legal-rag-service
API_V1_PREFIX=/api/v1

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_rag
POSTGRES_USER=legal_rag
POSTGRES_PASSWORD=legal_rag_password
DATABASE_URL=postgresql+psycopg://legal_rag:legal_rag_password@localhost:5432/legal_rag

# AI / RAG
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIRECTORY=./chroma_db
RAG_TOP_K=5

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
